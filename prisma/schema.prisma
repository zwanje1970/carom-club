  internalPage      String?
  internalPath      String?
  externalUrl       String?
  openInNewTab      Boolean   @default(false)
  buttons           String?
  isVisible         Boolean   @default(true)
  sortOrder         Int       @default(0)
  startAt           DateTime?
  endAt             DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  backgroundColor   String?
  titleIconImageUrl String?
  titleIconName     String?
  titleIconSize     String?
  titleIconType     String?
  sectionStyleJson  String?
  /// 페이지 구조 슬롯(hero, postList 등). null이면 레거시 CMS 행 — type(image|text|cta)만 사용
  slotType          String?
  /// 슬롯별 소량 설정 JSON. 자유 HTML 금지
  slotConfigJson    String?
  /// 페이지 빌더 소프트 삭제(복원 가능). DB 컬럼은 `20260329170000_page_section_deleted_at` 한 곳에서만 추가(중복 마이그레이션 금지).
  deletedAt         DateTime?

  @@index([page, placement])
  @@index([page])
  @@index([page, slotType, sortOrder])
}

model Popup {
  id                  String    @id @default(cuid())
  title               String
  description         String?
  imageUrl            String?
  buttonName          String?
  buttonLink          String?
  page                String
  startAt             DateTime?
  endAt               DateTime?
  hideForTodayEnabled Boolean   @default(true)
  showCloseButton     Boolean   @default(true)
  isVisible           Boolean   @default(true)
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([page])
}

model NoticeBar {
  id              String    @id @default(cuid())
  message         String
  linkType        String    @default("none")
  internalPath    String?
  externalUrl     String?
  openInNewTab    Boolean   @default(false)
  backgroundColor String    @default("#1e3a5f")
  textColor       String    @default("#ffffff")
  page            String
  position        String    @default("below_header")
  startAt         DateTime?
  endAt           DateTime?
  isVisible       Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([page])
}

model Notice {
  id          String    @id @default(cuid())
  type        String
  title       String
  content     String    @default("")
  linkUrl     String?
  startAt     DateTime?
  endAt       DateTime?
  isActive    Boolean   @default(true)
  showOnce    Boolean   @default(false)
  showMobile  Boolean   @default(true)
  showDesktop Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([isActive, type])
}

model BilliardNote {
  id                   String            @id @default(cuid())
  authorId             String
  title                String?
  noteDate             DateTime?
  redBallX             Float
  redBallY             Float
  yellowBallX          Float
  yellowBallY          Float
  whiteBallX           Float
  whiteBallY           Float
  cueBall              String
  memo                 String?
  imageUrl             String?
  visibility           String            @default("private")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  author               User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  nanguPostsFromNote   NanguPost?
  troubleShotsFromNote TroubleShotPost[]

  @@index([authorId])
  @@index([visibility, createdAt])
}

model NanguPost {
  id                String          @id @default(cuid())
  authorId          String
  title             String
  content           String
  ballPlacementJson String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  adoptedSolutionId String?         @unique(map: "NanguPost_adoptedSolutionId_key_v2")
  sourceNoteId      String?         @unique
  adoptedSolution   NanguSolution?  @relation("AdoptedSolution", fields: [adoptedSolutionId], references: [id])
  author            User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sourceNote        BilliardNote?   @relation(fields: [sourceNoteId], references: [id])
  solutions         NanguSolution[]

  @@index([authorId])
  @@index([createdAt])
}

model NanguSolution {
  id                    String                  @id @default(cuid())
  postId                String
  authorId              String
  createdAt             DateTime                @default(now())
  description           String?
  isAccepted            Boolean                 @default(false)
  pathData              Json
  playbackFrames        Json?
  settings              Json
  thumbnailSvg          String?
  title                 String?
  comment               String?
  dataJson              String                  @default("{}")
  voteCount             Int                     @default(0)
  goodCount             Int                     @default(0)
  badCount              Int                     @default(0)
  updatedAt             DateTime                @default(now()) @updatedAt
  adoptedByPost         NanguPost?              @relation("AdoptedSolution")
  author                User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post                  NanguPost               @relation(fields: [postId], references: [id], onDelete: Cascade)
  NanguSolutionComment  NanguSolutionComment[]
  NanguSolutionReaction NanguSolutionReaction[]

  @@index([postId])
  @@index([authorId])
}

model CommunityBoard {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  description String?
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  type        String          @default("free")
  isActive    Boolean         @default(true)
  posts       CommunityPost[]

  @@index([sortOrder])
  @@index([type, isActive])
}

model CommunityPost {
  id           String              @id @default(cuid())
  boardId      String
  authorId     String
  title        String
  content      String
  imageUrls    String?
  isPinned     Boolean             @default(false)
  isHidden     Boolean             @default(false)
  viewCount    Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  thumbnailUrl String?
  likeCount    Int                 @default(0)
  commentCount Int                 @default(0)
  isSolved     Boolean             @default(false)
  bookmarks    CommunityBookmark[]
  comments     CommunityComment[]
  author       User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  board        CommunityBoard      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  likes        CommunityPostLike[]
  postViews    CommunityPostView[]
  reports      CommunityReport[]
  troubleShot  TroubleShotPost?

  @@index([boardId])
  @@index([authorId])
  @@index([boardId, isPinned, createdAt])
  @@index([boardId, isHidden, createdAt])
  @@index([boardId, isHidden, viewCount])
  @@index([boardId, isHidden, likeCount])
  @@index([boardId, isHidden, commentCount])
  @@index([boardId, isHidden, isSolved, createdAt])
  @@index([boardId, isHidden, title])
  @@index([createdAt])
  @@index([isHidden])
  @@index([title(ops: raw("gin_trgm_ops"))], map: "CommunityPost_title_gin_trgm_idx", type: Gin)
}

model CommunityPostView {
  id        String        @id @default(cuid())
  postId    String
  viewerKey String
  userId    String?
  viewedAt  DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, viewerKey])
  @@index([postId])
  @@index([viewedAt])
}

model CommunityComment {
  id        String                 @id @default(cuid())
  postId    String
  parentId  String?
  authorId  String
  content   String
  isHidden  Boolean                @default(false)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  author    User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    CommunityComment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  children  CommunityComment[]     @relation("CommentReplies")
  post      CommunityPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  likes     CommunityCommentLike[]
  reports   CommunityReport[]

  @@index([postId])
  @@index([parentId])
  @@index([authorId])
}

model CommunityPostLike {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model CommunityCommentLike {
  id        String           @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime         @default(now())
  comment   CommunityComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model CommunityBookmark {
  id        String        @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model CommunityNotification {
  id            String    @id @default(cuid())
  userId        String
  type          String
  postId        String
  commentId     String?
  relatedUserId String
  readAt        DateTime?
  createdAt     DateTime  @default(now())
  relatedUser   User      @relation("NotificationActor", fields: [relatedUserId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@map("community_notifications")
}

model CommunityReport {
  id          String            @id @default(cuid())
  reporterId  String
  targetType  String
  targetId    String
  postId      String?
  commentId   String?
  reason      String
  status      String            @default("PENDING")
  adminMemo   String?
  processedAt DateTime?
  processedBy String?
  createdAt   DateTime          @default(now())
  comment     CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  post        CommunityPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter    User              @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([status])
}

model CommunityScoreLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Int
  refType   String?
  refId     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model TroubleShotPost {
  id                 String                @id @default(cuid())
  postId             String                @unique
  sourceNoteId       String?
  layoutImageUrl     String?
  difficulty         String?
  isSolved           Boolean               @default(false)
  acceptedSolutionId String?
  ballPlacementJson  String?
  post               CommunityPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  sourceNote         BilliardNote?         @relation(fields: [sourceNoteId], references: [id])
  solutions          TroubleShotSolution[]

  @@index([postId])
  @@index([sourceNoteId])
  @@index([isSolved])
}

model TroubleShotSolution {
  id                String                    @id @default(cuid())
  troubleShotPostId String
  authorId          String
  title             String?
  content           String
  solutionImageUrl  String?
  voteCount         Int                       @default(0)
  isAccepted        Boolean                   @default(false)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  goodCount         Int                       @default(0)
  badCount          Int                       @default(0)
  solutionDataJson  String?
  author            User                      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  troubleShotPost   TroubleShotPost           @relation(fields: [troubleShotPostId], references: [id], onDelete: Cascade)
  votes             TroubleShotSolutionVote[]

  @@index([troubleShotPostId])
  @@index([authorId])
}

model TroubleShotSolutionVote {
  id         String                      @id @default(cuid())
  solutionId String
  userId     String
  vote       TroubleShotSolutionVoteType
  createdAt  DateTime                    @default(now())
  solution   TroubleShotSolution         @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  user       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([solutionId, userId])
  @@index([solutionId])
  @@index([userId])
}

model Inquiry {
  id        String    @id @default(cuid())
  userId    String
  title     String
  content   String
  reply     String?
  replyAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ClientFeedback {
  id        String   @id @default(cuid())
  type      String
  title     String
  content   String
  imageUrl  String?
  pagePath  String?
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model NanguSolutionComment {
  id            String        @id
  solutionId    String
  userId        String
  content       String
  createdAt     DateTime      @default(now())
  NanguSolution NanguSolution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  User          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([solutionId])
  @@index([userId])
}

model NanguSolutionReaction {
  solutionId    String
  userId        String
  type          NanguSolutionReactionType
  NanguSolution NanguSolution             @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  User          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([solutionId, userId])
  @@index([solutionId])
  @@index([userId])
}

