  previousMatches  BracketMatch[]     @relation("BracketMatchNext")
  round            BracketRound       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  venue            Venue?             @relation(fields: [venueId], references: [id])
  winnerEntry      TournamentEntry?   @relation("BracketMatchWinner", fields: [winnerEntryId], references: [id])

  @@index([bracketId, roundId, matchNumber])
  @@index([venueId])
  @@index([nextMatchId])
}

