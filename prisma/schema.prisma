generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id              String           @id @default(cuid())
  key             String           @unique
  label           String
  isSystem        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  description     String?
  rolePermissions RolePermission[]
  users           User[]           @relation("UserRbacRole")
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  label           String
  category        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model User {
  id                              String                          @id @default(cuid())
  name                            String
  username                        String                          @unique
  password                        String
  email                           String
  phone                           String?
  createdAt                       DateTime                        @default(now())
  updatedAt                       DateTime                        @updatedAt
  withdrawnAt                     DateTime?
  status                          String?
  address                         String?
  addressDetail                   String?
  latitude                        Float?
  longitude                       Float?
  role                            UserRole                        @default(USER)
  communityScore                  Int                             @default(0)
  roleId                          String?
  activityPoint                   Int                             @default(0)
  roleManualLocked                Boolean                         @default(false)
  billiardNotes                   BilliardNote[]
  bracketAuditLogs                BracketAuditLog[]
  clientApplications              ClientApplication[]
  clientFeedbacks                 ClientFeedback[]
  communityBookmarks              CommunityBookmark[]
  communityComments               CommunityComment[]
  communityCommentLikes           CommunityCommentLike[]
  communityPosts                  CommunityPost[]
  communityPostLikes              CommunityPostLike[]
  communityReports                CommunityReport[]
  communityScoreLogs              CommunityScoreLog[]
  inquiries                       Inquiry[]
  leagueAuditLogs                 LeagueAuditLog[]
  memberProfile                   MemberProfile?
  nanguPosts                      NanguPost[]
  nanguSolutions                  NanguSolution[]
  NanguSolutionComment            NanguSolutionComment[]
  NanguSolutionReaction           NanguSolutionReaction[]
  notifications                   Notification[]
  orgMemberships                  OrganizationMember[]
  passwordResetTokens             PasswordResetToken[]
  pushSubscriptions               PushSubscription[]
  tournamentsCreated              Tournament[]
  tournamentAttendances           TournamentAttendance[]
  clientMemberships               ClientMembership[]
  tournamentEntries               TournamentEntry[]
  entryZoneAssignmentsGranted     TournamentEntryZoneAssignment[]
  waitlistEntries                 TournamentWaitlistEntry[]
  zoneManagerApprovedZones        TournamentZoneManager[]         @relation("TournamentZoneManagerApprovedBy")
  zoneManagerManagedZones         TournamentZoneManager[]
  troubleShotSolutions            TroubleShotSolution[]
  troubleShotSolutionVotes        TroubleShotSolutionVote[]
  rbacRole                        Role?                           @relation("UserRbacRole", fields: [roleId], references: [id])
  activityPoints                  UserActivityPoint[]
  zoneManagerApplicationsReviewed ZoneManagerApplication[]        @relation("ZoneManagerApplicationReviewedBy")
  zoneManagerApplications         ZoneManagerApplication[]
  zoneManagerAssignments          ZoneManagerAssignment[]
  communityNotificationsAsRelated CommunityNotification[]         @relation("NotificationActor")
  communityNotifications          CommunityNotification[]

  @@index([roleId])
}

model UserActivityPoint {
  id             String   @id @default(cuid())
  userId         String
  type           String
  points         Int
  refType        String?
  refId          String?
  description    String?
  idempotencyKey String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([refType, refId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model MemberProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  handicap          String?
  avg               String?
  avgProofUrl       String?
  avgProofExpiresAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientApplication {
  id                  String    @id @default(cuid())
  type                String
  status              String    @default("PENDING")
  applicantUserId     String?
  organizationName    String
  applicantName       String
  phone               String
  email               String
  region              String?
  shortDescription    String?
  referenceLink       String?
  rejectedReason      String?
  reviewedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  requestedClientType String?   @default("GENERAL")
  reviewedByUserId    String?
  applicant           User?     @relation(fields: [applicantUserId], references: [id])

  @@index([status])
  @@index([applicantUserId])
}

model Organization {
  id                      String                         @id @default(cuid())
  slug                    String?                        @unique
  name                    String
  description             String?
  promoDraft              String?
  promoPublished          String?
  promoPublishedAt        DateTime?
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  status                  String                         @default("ACTIVE")
  adminRemarks            String?
  address                 String?
  addressNaverMapEnabled  Boolean?                       @default(false)
  coverImageUrl           String?
  email                   String?
  fullDescription         String?
  isPublished             Boolean                        @default(false)
  latitude                Float?
  logoImageUrl            String?
  longitude               Float?
  ownerUserId             String?
  phone                   String?
  region                  String?
  setupCompleted          Boolean                        @default(false)
  shortDescription        String?
  typeSpecificJson        String?
  website                 String?
  type                    String                         @default("CLUB")
  addressDetail           String?
  approvalStatus          String?
  clientType              String?                        @default("GENERAL")
  membershipType          String?
  membershipExpireDate    DateTime?
  promoPdfUrl             String?
  promoImageUrl           String?
  organizationMemberships OrganizationMembership[]
  listingPurchases        ListingPurchaseRecord[]
  featureAccesses         OrganizationFeatureAccess[]
  feePayments             OrganizationFeePayment[]
  feeSetting              OrganizationFeeSetting?
  members                 OrganizationMember[]
  planSubscriptions       OrganizationPlanSubscription[]
  paymentRecords          PaymentRecord[]
  tournaments             Tournament[]
  tournamentVenues        TournamentVenue[]
}

model Client {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  defaultTableCount Int                @default(1)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tournaments       Tournament[]
  memberships       ClientMembership[]
  venues            Venue[]
}

model ClientMembership {
  id        String                 @id @default(cuid())
  userId    String
  clientId  String
  role      ClientMembershipRole   @default(MEMBER)
  status    ClientMembershipStatus @default(PENDING)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  client    Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([clientId])
  @@index([userId])
  @@map("TournamentClientMembership")
}

model OrganizationFeeSetting {
  id             String       @id @default(cuid())
  organizationId String       @unique
  feeType        String
  amountInWon    Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationFeePayment {
  id             String       @id @default(cuid())
  organizationId String
  amountInWon    Int
  paidAt         DateTime
  period         String
  memo           String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, period])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?
  role           String       @default("MEMBER")
  status         String       @default("ACTIVE")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model PromoPageTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String
  thumbnailUrl String?
  contentHtml  String
  isDefault    Boolean  @default(false)
  createdById  String?
  createdAt    DateTime @default(now())

  @@index([isDefault])
  @@index([category])
}

model Tournament {
  id                         String                         @id @default(cuid())
  organizationId             String
  name                       String
  slug                       String?
  description                String?
  startAt                    DateTime
  endAt                      DateTime?
  imageUrl                   String?
  venue                      String?
  gameFormat                 String?
  status                     String                         @default("OPEN")
  outlineDraft               String?
  outlinePublished           String?
  outlinePublishedAt         DateTime?
  createdAt                  DateTime                       @default(now())
  updatedAt                  DateTime                       @updatedAt
  title                      String?
  approvalType               String                         @default("HOST_APPROVAL")
  entryCondition             String?
  entryFee                   Int?
  maxParticipants            Int?
  posterImageUrl             String?
  prizeInfo                  String?
  promoContent               String?
  qualification              String?
  region                     String?
  rules                      String?
  summary                    String?
  venueName                  String?
  createdByUserId            String?
  tournamentStage            String                         @default("SETUP")
  isPromoted                 Boolean                        @default(false)
  promotionLevel             Int?
  promotionEndDate           DateTime?
  outlinePdfUrl              String?
  /// 대진표 생성 전 참가 명단 확정 시각. 설정 후 확정자 목록 스냅샷과 함께 고정되며, 신청/입금확인/취소 등 변경이 제한됨.
  participantRosterLockedAt  DateTime?
  /// 확정 시점 CONFIRMED entry id 목록 등 JSON (lib/tournament-participant-roster.ts 스키마)
  participantRosterSnapshot  String?
  /// 전국대회 필터용 — region 문자열 파싱 대신 등치 인덱스 조회 (마이그레이션으로 기존 행 백필)
  nationalTournament         Boolean                        @default(false)
  /// 구 필드(호환 전용, 신규 로직에서 직접 사용 금지)
  certificationRequestMode   String                         @default("NONE")
  manualReviewRequired       Boolean                        @default(true)
  eligibilityLimitType       String?
  eligibilityLimitValue      Float?
  /// 인증파일 요청 mode (신규 표준)
  verificationMode           VerificationMode               @default(NONE)
  /// 인증·자격 운영 검토 필요 여부
  verificationReviewRequired Boolean                        @default(true)
  /// 참가 제한 type (신규 표준)
  eligibilityType            EligibilityType                @default(NONE)
  /// eligibilityType=UNDER일 때 회원 AVG가 이 값 **미만**이어야 신청 가능 (엄격한 `<`)
  eligibilityValue           Float?
  /// 신청 페이지 인증 안내 문구 (선택)
  verificationGuideText      String?
  /// 자동 부 분배 ON/OFF
  divisionEnabled            Boolean                        @default(false)
  /// [{name,min,max}, ...] JSON 규칙
  divisionRulesJson          Json?
  /// 자동 부 분배 기준값 타입 (AVERAGE|SCORE)
  divisionMetricType         DivisionMetricType             @default(AVERAGE)
  clientId                   String?
  type                       TournamentType                 @default(NORMAL)
  recruitmentStatus          TournamentRecruitmentStatus    @default(RECRUITING)
  bracketMode                BracketMode                    @default(SINGLE_ELIM)
  seedingMode                BracketSeedingMode             @default(RANDOM)
  byeStrategy                ByeStrategy                    @default(EARLY)
  targetFinalSize            Int?
  duplicateApplyAllowed      Boolean                        @default(false)
  recruitOpenAt              DateTime?
  recruitCloseAt             DateTime?
  isScotch                   Boolean                        @default(false)
  teamScoreLimit             Int?
  teamScoreRule              TeamScoreRule                  @default(LTE)
  tvAccessToken              String?                        @unique
  tvAccessTokenIssuedAt      DateTime?
  brackets                   Bracket[]
  bracketAuditLogs           BracketAuditLog[]
  leagues                    League[]
  leagueAuditLogs            LeagueAuditLog[]
  client                     Client?                        @relation(fields: [clientId], references: [id])
  createdBy                  User?                          @relation(fields: [createdByUserId], references: [id])
  organization               Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries                    TournamentEntry[]
  finalMatches               TournamentFinalMatch[]
  finalMatchAuditLogs        TournamentFinalMatchAuditLog[]
  finalQualifiers            TournamentFinalQualifier[]
  matchDays                  TournamentMatchDay[]
  matchVenues                TournamentMatchVenue[]
  rounds                     TournamentRound[]
  rule                       TournamentRule?
  settlement                 TournamentSettlement?
  tournamentVenues           TournamentVenue[]
  waitlistEntries            TournamentWaitlistEntry[]
  tournamentZones            TournamentZone[]
  venues                     Venue[]
  zoneManagerApplications    ZoneManagerApplication[]

  @@index([status, startAt])
  @@index([nationalTournament])
  @@index([tvAccessToken])
}

/// 대회 종료 후 참가비·환불·상금·비용 등을 기록 (대회별 1건 + 라인 아이템)
model TournamentSettlement {
  id             String                     @id @default(cuid())
  tournamentId   String                     @unique
  status         String                     @default("DRAFT")
  memo           String?
  lockedAt       DateTime?
  lockedByUserId String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  tournament     Tournament                 @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  lines          TournamentSettlementLine[]
}

model TournamentSettlementLine {
  id           String               @id @default(cuid())
  settlementId String
  category     String
  label        String?
  flow         String
  amountKrw    Int
  note         String?
  sortOrder    Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  settlement   TournamentSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
}

model TournamentMatchVenue {
  id             String                 @id @default(cuid())
  tournamentId   String
  venueNumber    Int
  displayLabel   String
  venueName      String?
  address        String?
  phone          String?
  sortOrder      Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  bracketMatches TournamentFinalMatch[]
  tournament     Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, venueNumber])
  @@index([tournamentId])
}

model TournamentVenue {
  id             String       @id @default(cuid())
  tournamentId   String
  organizationId String
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tournament     Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, organizationId])
  @@index([tournamentId])
  @@index([organizationId])
}

model TournamentRule {
  id              String     @id @default(cuid())
  tournamentId    String     @unique
  entryFee        Int?
  operatingFee    Int?
  maxEntries      Int?
  useWaiting      Boolean    @default(false)
  entryConditions String?
  bracketType     String?
  bracketConfig   String?
  prizeType       String?
  prizeInfo       String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model TournamentEntry {
  id                            String                         @id @default(cuid())
  tournamentId                  String
  userId                        String
  depositorName                 String?
  paidAt                        DateTime?
  round                         String?
  prize                         Int?
  waitingListOrder              Int?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  status                        String                         @default("APPLIED")
  clubOrAffiliation             String?
  paymentMarkedByApplicantAt    DateTime?
  rejectionReason               String?
  reviewedAt                    DateTime?
  entryFeeAmount                Int?
  slotNumber                    Int                            @default(1)
  avg                           String?
  avgProofUrl                   String?
  handicap                      String?
  /// 구 필드(호환 전용)
  certificationImageUrl         String?
  certificationOriginalFilename String?
  certificationMimeType         String?
  certificationOcrText          String?
  certificationOcrStatus        String?
  certificationReviewStatus     String?
  certificationReviewedAt       DateTime?
  certificationReviewedById     String?
  /// 인증파일(신규 표준)
  verificationImageUrl          String?
  verificationOcrText           String?
  verificationOcrStatus         VerificationOcrStatus?
  verificationReviewStatus      VerificationReviewStatus?
  divisionName                  String?
  divisionMatchedAverage        Float?
  divisionMatchedValue          Float?
  matchDayId                    String?
  zoneId                        String?
  displayName                   String?
  levelCode                     String?
  levelConfirmed                Boolean                        @default(false)
  entryStatus                   TournamentEntryStatus          @default(APPLIED)
  isWaitlist                    Boolean                        @default(false)
  duplicateGroupKey             String?
  checkedInAt                   DateTime?
  seedNumber                    Int?
  bracketOrder                  Int?
  playerAName                   String?
  playerAScore                  Int?
  playerAProof                  String?
  playerBName                   String?
  playerBScore                  Int?
  playerBProof                  String?
  teamTotalScore                Int?
  bracketMatchesAsA             BracketMatch[]                 @relation("BracketMatchEntryA")
  bracketMatchesAsB             BracketMatch[]                 @relation("BracketMatchEntryB")
  bracketMatchesAsWinner        BracketMatch[]                 @relation("BracketMatchWinner")
  leagueMatchesAsA              LeagueMatch[]                  @relation("LeagueMatchEntryA")
  leagueMatchesAsB              LeagueMatch[]                  @relation("LeagueMatchEntryB")
  leagueStandings               LeagueStanding[]
  attendances                   TournamentAttendance[]
  matchDay                      TournamentMatchDay?            @relation(fields: [matchDayId], references: [id])
  tournament                    Tournament                     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user                          User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone                          TournamentZone?                @relation(fields: [zoneId], references: [id])
  zoneAssignment                TournamentEntryZoneAssignment?

  @@unique([tournamentId, userId, slotNumber])
  @@index([tournamentId])
  @@index([userId])
}

model TournamentAttendance {
  id        String          @id @default(cuid())
  entryId   String
  userId    String
  attended  Boolean         @default(true)
  createdAt DateTime        @default(now())
  entry     TournamentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId])
  @@index([entryId])
  @@index([userId])
}

model TournamentRound {
  id           String                 @id @default(cuid())
  tournamentId String
  name         String
  sortOrder    Int                    @default(0)
  bracketData  String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  finalMatches TournamentFinalMatch[]
  groups       TournamentGroup[]
  tournament   Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model TournamentGroup {
  id        String                  @id @default(cuid())
  roundId   String
  name      String?
  sortOrder Int                     @default(0)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  round     TournamentRound         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  members   TournamentGroupMember[]
  results   TournamentResult[]
}

model TournamentGroupMember {
  id        String          @id @default(cuid())
  groupId   String
  entryId   String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  group     TournamentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model TournamentResult {
  id        String          @id @default(cuid())
  groupId   String
  entryId   String?
  rank      Int?
  score     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  group     TournamentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model Zone {
  id                 String                  @id @default(cuid())
  name               String
  code               String?
  sortOrder          Int                     @default(0)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  tournamentZones    TournamentZone[]
  managerAssignments ZoneManagerAssignment[]
}

model TournamentZone {
  id              String                          @id @default(cuid())
  tournamentId    String
  zoneId          String
  name            String?
  code            String?
  sortOrder       Int                             @default(0)
  status          String?
  advanceCount    Int                             @default(1)
  advanceRuleType String                          @default("WINNER_ONLY")
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  matchDayId      String?
  venueId         String?
  workflowStatus  TournamentZoneStatus            @default(READY)
  qualifierTarget Int?
  brackets        Bracket[]
  leagues         League[]
  entries         TournamentEntry[]
  zoneAssignments TournamentEntryZoneAssignment[]
  finalQualifiers TournamentFinalQualifier[]
  waitlistEntries TournamentWaitlistEntry[]
  matchDay        TournamentMatchDay?             @relation(fields: [matchDayId], references: [id])
  tournament      Tournament                      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  venue           Venue?                          @relation(fields: [venueId], references: [id])
  zone            Zone                            @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  managers        TournamentZoneManager[]
  zoneMatches     TournamentZoneMatch[]
  applications    ZoneManagerApplication[]

  @@unique([tournamentId, zoneId])
  @@index([tournamentId])
  @@index([zoneId])
}

model TournamentZoneMatch {
  id               String         @id @default(cuid())
  tournamentId     String
  tournamentZoneId String
  roundIndex       Int
  matchIndex       Int
  entryIdA         String?
  entryIdB         String?
  scoreA           Int?
  scoreB           Int?
  winnerEntryId    String?
  status           String         @default("PENDING")
  nextMatchId      String?
  nextSlot         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tournamentZone   TournamentZone @relation(fields: [tournamentZoneId], references: [id], onDelete: Cascade)

  @@index([tournamentZoneId])
  @@index([tournamentId])
}

model TournamentFinalQualifier {
  id               String         @id @default(cuid())
  tournamentId     String
  tournamentZoneId String
  entryId          String
  qualifiedRank    Int
  sourceMatchId    String?
  seedOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  tournament       Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentZone   TournamentZone @relation(fields: [tournamentZoneId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, tournamentZoneId, qualifiedRank])
  @@index([tournamentId])
  @@index([tournamentZoneId])
}

model TournamentFinalMatch {
  id                String                @id @default(cuid())
  tournamentId      String
  roundIndex        Int
  matchIndex        Int
  entryIdA          String?
  entryIdB          String?
  scoreA            Int?
  scoreB            Int?
  winnerEntryId     String?
  status            String                @default("PENDING")
  nextMatchId       String?
  nextSlot          String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  /// 라운드 묶음(예: 단판 본체 / 본선 브래킷). 없으면 null — 레거시·권역 본선 전용 생성분.
  tournamentRoundId String?
  /// 당구장 대회 MVP 경기장 슬롯(1경기장, 2경기장…). 미배정 시 null.
  matchVenueId      String?
  /// MAIN=일반 본선/단판, QUALIFIER=예선권역과 구분 시, PLAY_IN 등
  bracketPhase      String                @default("MAIN")
  /// 운영 콘솔 예정 시작 시각 (로컬 표시는 클라이언트에서 변환)
  scheduledStartAt  DateTime?
  /// 문제 경기 플래그 (현장 이슈·재배정 필요 등)
  hasIssue          Boolean               @default(false)
  issueNote         String?
  matchVenue        TournamentMatchVenue? @relation(fields: [matchVenueId], references: [id])
  tournament        Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentRound   TournamentRound?      @relation(fields: [tournamentRoundId], references: [id])

  @@index([tournamentId])
  @@index([tournamentRoundId])
  @@index([matchVenueId])
  @@index([tournamentId, bracketPhase, roundIndex, matchIndex])
}

/// 본선/단판 Match 수정 감사(결과·상태 변경 추적). bracketConfig 정책과 별도로 이력 적재.
