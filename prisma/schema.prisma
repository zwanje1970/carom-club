generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id              String           @id @default(cuid())
  key             String           @unique
  label           String
  isSystem        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  description     String?
  rolePermissions RolePermission[]
  users           User[]           @relation("UserRbacRole")
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  label           String
  category        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model User {
  id                              String                          @id @default(cuid())
  name                            String
  username                        String                          @unique
  password                        String
  email                           String
  phone                           String?
  createdAt                       DateTime                        @default(now())
  updatedAt                       DateTime                        @updatedAt
  withdrawnAt                     DateTime?
  status                          String?
  address                         String?
  addressDetail                   String?
  latitude                        Float?
  longitude                       Float?
  role                            UserRole                        @default(USER)
  communityScore                  Int                             @default(0)
  roleId                          String?
  activityPoint                   Int                             @default(0)
  roleManualLocked                Boolean                         @default(false)
  billiardNotes                   BilliardNote[]
  clientApplications              ClientApplication[]
  communityBookmarks              CommunityBookmark[]
  communityComments               CommunityComment[]
  communityCommentLikes           CommunityCommentLike[]
  communityPosts                  CommunityPost[]
  communityPostLikes              CommunityPostLike[]
  communityReports                CommunityReport[]
  communityScoreLogs              CommunityScoreLog[]
  inquiries                       Inquiry[]
  memberProfile                   MemberProfile?
  nanguPosts                      NanguPost[]
  nanguSolutions                  NanguSolution[]
  NanguSolutionComment            NanguSolutionComment[]
  NanguSolutionReaction           NanguSolutionReaction[]
  notifications                   Notification[]
  orgMemberships                  OrganizationMember[]
  passwordResetTokens             PasswordResetToken[]
  pushSubscriptions               PushSubscription[]
  tournamentsCreated              Tournament[]
  tournamentAttendances           TournamentAttendance[]
  tournamentEntries               TournamentEntry[]
  entryZoneAssignmentsGranted     TournamentEntryZoneAssignment[]
  troubleShotSolutions            TroubleShotSolution[]
  troubleShotSolutionVotes        TroubleShotSolutionVote[]
  rbacRole                        Role?                           @relation("UserRbacRole", fields: [roleId], references: [id])
  activityPoints                  UserActivityPoint[]
  zoneManagerAssignments          ZoneManagerAssignment[]
  communityNotificationsAsRelated CommunityNotification[]         @relation("NotificationActor")
  communityNotifications          CommunityNotification[]

  @@index([roleId])
}

model UserActivityPoint {
  id             String   @id @default(cuid())
  userId         String
  type           String
  points         Int
  refType        String?
  refId          String?
  description    String?
  idempotencyKey String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([refType, refId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model MemberProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  handicap          String?
  avg               String?
  avgProofUrl       String?
  avgProofExpiresAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientApplication {
  id                  String    @id @default(cuid())
  type                String
  status              String    @default("PENDING")
  applicantUserId     String?
  organizationName    String
  applicantName       String
  phone               String
  email               String
  region              String?
  shortDescription    String?
  referenceLink       String?
  rejectedReason      String?
  reviewedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  requestedClientType String?   @default("GENERAL")
  reviewedByUserId    String?
  applicant           User?     @relation(fields: [applicantUserId], references: [id])

  @@index([status])
  @@index([applicantUserId])
}

model Organization {
  id                     String                         @id @default(cuid())
  slug                   String?                        @unique
  name                   String
  description            String?
  promoDraft             String?
  promoPublished         String?
  promoPublishedAt       DateTime?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  status                 String                         @default("ACTIVE")
  adminRemarks           String?
  address                String?
  addressNaverMapEnabled Boolean?                       @default(false)
  coverImageUrl          String?
  email                  String?
  fullDescription        String?
  isPublished            Boolean                        @default(false)
  latitude               Float?
  logoImageUrl           String?
  longitude              Float?
  ownerUserId            String?
  phone                  String?
  region                 String?
  setupCompleted         Boolean                        @default(false)
  shortDescription       String?
  typeSpecificJson       String?
  website                String?
  type                   String                         @default("CLUB")
  addressDetail          String?
  approvalStatus         String?
  clientType             String?                        @default("GENERAL")
  membershipType         String?
  membershipExpireDate   DateTime?
  promoPdfUrl            String?
  promoImageUrl          String?
  clientMemberships      ClientMembership[]
  listingPurchases       ListingPurchaseRecord[]
  featureAccesses        OrganizationFeatureAccess[]
  feePayments            OrganizationFeePayment[]
  feeSetting             OrganizationFeeSetting?
  members                OrganizationMember[]
  planSubscriptions      OrganizationPlanSubscription[]
  paymentRecords         PaymentRecord[]
  tournaments            Tournament[]
  tournamentVenues       TournamentVenue[]
}

model OrganizationFeeSetting {
  id             String       @id @default(cuid())
  organizationId String       @unique
  feeType        String
  amountInWon    Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationFeePayment {
  id             String       @id @default(cuid())
  organizationId String
  amountInWon    Int
  paidAt         DateTime
  period         String
  memo           String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, period])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?
  role           String       @default("MEMBER")
  status         String       @default("ACTIVE")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model PromoPageTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String
  thumbnailUrl String?
  contentHtml  String
  isDefault    Boolean  @default(false)
  createdById  String?
  createdAt    DateTime @default(now())

  @@index([isDefault])
  @@index([category])
}

model Tournament {
  id                        String                         @id @default(cuid())
  organizationId            String
  name                      String
  slug                      String?
  description               String?
  startAt                   DateTime
  endAt                     DateTime?
  imageUrl                  String?
  venue                     String?
  gameFormat                String?
  status                    String                         @default("OPEN")
  outlineDraft              String?
  outlinePublished          String?
  outlinePublishedAt        DateTime?
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  title                     String?
  approvalType              String                         @default("HOST_APPROVAL")
  entryCondition            String?
  entryFee                  Int?
  maxParticipants           Int?
  posterImageUrl            String?
  prizeInfo                 String?
  promoContent              String?
  qualification             String?
  region                    String?
  rules                     String?
  summary                   String?
  venueName                 String?
  createdByUserId           String?
  tournamentStage           String                         @default("SETUP")
  isPromoted                Boolean                        @default(false)
  promotionLevel            Int?
  promotionEndDate          DateTime?
  outlinePdfUrl             String?
  /// 대진표 생성 전 참가 명단 확정 시각. 설정 후 확정자 목록 스냅샷과 함께 고정되며, 신청/입금확인/취소 등 변경이 제한됨.
  participantRosterLockedAt DateTime?
  /// 확정 시점 CONFIRMED entry id 목록 등 JSON (lib/tournament-participant-roster.ts 스키마)
  participantRosterSnapshot String?
  /// 전국대회 필터용 — region 문자열 파싱 대신 등치 인덱스 조회 (마이그레이션으로 기존 행 백필)
  nationalTournament        Boolean                        @default(false)
  createdBy                 User?                          @relation(fields: [createdByUserId], references: [id])
  organization              Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries                   TournamentEntry[]
  finalMatches              TournamentFinalMatch[]
  finalMatchAuditLogs       TournamentFinalMatchAuditLog[]
  finalQualifiers           TournamentFinalQualifier[]
  matchVenues               TournamentMatchVenue[]
  rounds                    TournamentRound[]
  rule                      TournamentRule?
  settlement                TournamentSettlement?
  tournamentVenues          TournamentVenue[]
  tournamentZones           TournamentZone[]

  @@index([status, startAt])
  @@index([nationalTournament])
}

/// 대회 종료 후 참가비·환불·상금·비용 등을 기록 (대회별 1건 + 라인 아이템)
model TournamentSettlement {
  id             String                     @id @default(cuid())
  tournamentId   String                     @unique
  status         String                     @default("DRAFT")
  memo           String?
  lockedAt       DateTime?
  lockedByUserId String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  tournament     Tournament                 @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  lines          TournamentSettlementLine[]
}

model TournamentSettlementLine {
  id           String               @id @default(cuid())
  settlementId String
  category     String
  label        String?
  flow         String
  amountKrw    Int
  note         String?
  sortOrder    Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  settlement   TournamentSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
}

model TournamentMatchVenue {
  id             String                 @id @default(cuid())
  tournamentId   String
  venueNumber    Int
  displayLabel   String
  venueName      String?
  address        String?
  phone          String?
  sortOrder      Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  bracketMatches TournamentFinalMatch[]
  tournament     Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, venueNumber])
  @@index([tournamentId])
}

model TournamentVenue {
  id             String       @id @default(cuid())
  tournamentId   String
  organizationId String
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tournament     Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, organizationId])
  @@index([tournamentId])
  @@index([organizationId])
}

model TournamentRule {
  id              String     @id @default(cuid())
  tournamentId    String     @unique
  entryFee        Int?
  operatingFee    Int?
  maxEntries      Int?
  useWaiting      Boolean    @default(false)
  entryConditions String?
  bracketType     String?
  bracketConfig   String?
  prizeType       String?
  prizeInfo       String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model TournamentEntry {
  id                         String                         @id @default(cuid())
  tournamentId               String
  userId                     String
  depositorName              String?
  paidAt                     DateTime?
  round                      String?
  prize                      Int?
  waitingListOrder           Int?
  createdAt                  DateTime                       @default(now())
  updatedAt                  DateTime                       @updatedAt
  status                     String                         @default("APPLIED")
  clubOrAffiliation          String?
  paymentMarkedByApplicantAt DateTime?
  rejectionReason            String?
  reviewedAt                 DateTime?
  entryFeeAmount             Int?
  slotNumber                 Int                            @default(1)
  avg                        String?
  avgProofUrl                String?
  handicap                   String?
  attendances                TournamentAttendance[]
  tournament                 Tournament                     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user                       User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  zoneAssignment             TournamentEntryZoneAssignment?

  @@unique([tournamentId, userId, slotNumber])
  @@index([tournamentId])
  @@index([userId])
}

model TournamentAttendance {
  id        String          @id @default(cuid())
  entryId   String
  userId    String
  attended  Boolean         @default(true)
  createdAt DateTime        @default(now())
  entry     TournamentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId])
  @@index([entryId])
  @@index([userId])
}

model TournamentRound {
  id           String                 @id @default(cuid())
  tournamentId String
  name         String
  sortOrder    Int                    @default(0)
  bracketData  String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  finalMatches TournamentFinalMatch[]
  groups       TournamentGroup[]
  tournament   Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model TournamentGroup {
  id        String                  @id @default(cuid())
  roundId   String
  name      String?
  sortOrder Int                     @default(0)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  round     TournamentRound         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  members   TournamentGroupMember[]
  results   TournamentResult[]
}

model TournamentGroupMember {
  id        String          @id @default(cuid())
  groupId   String
  entryId   String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  group     TournamentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model TournamentResult {
  id        String          @id @default(cuid())
  groupId   String
  entryId   String?
  rank      Int?
  score     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  group     TournamentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model Zone {
  id                 String                  @id @default(cuid())
  name               String
  code               String?
  sortOrder          Int                     @default(0)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  tournamentZones    TournamentZone[]
  managerAssignments ZoneManagerAssignment[]
}

model TournamentZone {
  id              String                          @id @default(cuid())
  tournamentId    String
  zoneId          String
  name            String?
  code            String?
  sortOrder       Int                             @default(0)
  status          String?
  advanceCount    Int                             @default(1)
  advanceRuleType String                          @default("WINNER_ONLY")
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  zoneAssignments TournamentEntryZoneAssignment[]
  finalQualifiers TournamentFinalQualifier[]
  tournament      Tournament                      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  zone            Zone                            @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  zoneMatches     TournamentZoneMatch[]

  @@unique([tournamentId, zoneId])
  @@index([tournamentId])
  @@index([zoneId])
}

model TournamentZoneMatch {
  id               String         @id @default(cuid())
  tournamentId     String
  tournamentZoneId String
  roundIndex       Int
  matchIndex       Int
  entryIdA         String?
  entryIdB         String?
  scoreA           Int?
  scoreB           Int?
  winnerEntryId    String?
  status           String         @default("PENDING")
  nextMatchId      String?
  nextSlot         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tournamentZone   TournamentZone @relation(fields: [tournamentZoneId], references: [id], onDelete: Cascade)

  @@index([tournamentZoneId])
  @@index([tournamentId])
}

model TournamentFinalQualifier {
  id               String         @id @default(cuid())
  tournamentId     String
  tournamentZoneId String
  entryId          String
  qualifiedRank    Int
  sourceMatchId    String?
  seedOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  tournament       Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentZone   TournamentZone @relation(fields: [tournamentZoneId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, tournamentZoneId, qualifiedRank])
  @@index([tournamentId])
  @@index([tournamentZoneId])
}

model TournamentFinalMatch {
  id                String                @id @default(cuid())
  tournamentId      String
  roundIndex        Int
  matchIndex        Int
  entryIdA          String?
  entryIdB          String?
  scoreA            Int?
  scoreB            Int?
  winnerEntryId     String?
  status            String                @default("PENDING")
  nextMatchId       String?
  nextSlot          String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  /// 라운드 묶음(예: 단판 본체 / 본선 브래킷). 없으면 null — 레거시·권역 본선 전용 생성분.
  tournamentRoundId String?
  /// 당구장 대회 MVP 경기장 슬롯(1경기장, 2경기장…). 미배정 시 null.
  matchVenueId      String?
  /// MAIN=일반 본선/단판, QUALIFIER=예선권역과 구분 시, PLAY_IN 등
  bracketPhase      String                @default("MAIN")
  /// 운영 콘솔 예정 시작 시각 (로컬 표시는 클라이언트에서 변환)
  scheduledStartAt  DateTime?
  /// 문제 경기 플래그 (현장 이슈·재배정 필요 등)
  hasIssue          Boolean               @default(false)
  issueNote         String?
  matchVenue        TournamentMatchVenue? @relation(fields: [matchVenueId], references: [id])
  tournament        Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentRound   TournamentRound?      @relation(fields: [tournamentRoundId], references: [id])

  @@index([tournamentId])
  @@index([tournamentRoundId])
  @@index([matchVenueId])
  @@index([tournamentId, bracketPhase, roundIndex, matchIndex])
}

/// 본선/단판 Match 수정 감사(결과·상태 변경 추적). bracketConfig 정책과 별도로 이력 적재.
model TournamentFinalMatchAuditLog {
  id           String     @id @default(cuid())
  tournamentId String
  matchId      String
  actorUserId  String
  action       String
  summaryJson  String
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, matchId])
  @@index([createdAt])
}

model TournamentEntryZoneAssignment {
  id                String          @id @default(cuid())
  tournamentEntryId String          @unique
  tournamentZoneId  String
  assignmentType    String
  assignedAt        DateTime        @default(now())
  assignedByUserId  String?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  assignedBy        User?           @relation(fields: [assignedByUserId], references: [id])
  entry             TournamentEntry @relation(fields: [tournamentEntryId], references: [id], onDelete: Cascade)
  tournamentZone    TournamentZone  @relation(fields: [tournamentZoneId], references: [id], onDelete: Cascade)

  @@index([tournamentZoneId])
}

model ZoneManagerAssignment {
  id        String   @id @default(cuid())
  userId    String
  zoneId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([userId, zoneId])
  @@index([userId])
  @@index([zoneId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  message   String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}

model NotificationLog {
  id           String    @id @default(cuid())
  userId       String
  tournamentId String?
  type         String
  title        String
  body         String?
  url          String?
  status       String    @default("PENDING")
  errorMessage String?
  createdAt    DateTime  @default(now())
  sentAt       DateTime?

  @@index([userId])
  @@index([tournamentId])
  @@index([type, createdAt])
}

model SiteSetting {
  id                      String   @id @default(cuid())
  siteName                String   @default("CAROM.CLUB")
  siteDescription         String?
  logoUrl                 String?
  primaryColor            String   @default("#d97706")
  secondaryColor          String   @default("#b91c1c")
  updatedAt               DateTime @updatedAt
  heroSettingsJson        String?
  withdrawRejoinDays      Int      @default(0)
  footerAddress           String?
  footerBgColor           String?
  footerBusinessNumber    String?
  footerCeoName           String?
  footerCompanyName       String?
  footerCopyright         String?
  footerEmail             String?
  footerEnabled           Boolean  @default(false)
  footerPartnersJson      String?
  footerPhone             String?
  footerTextColor         String?
  footerTitle             String?
  headerActiveColor       String?
  headerBgColor           String?
  headerTextColor         String?
  footerFontSize          String?
  footerFontSizesJson     String?
  footerFontFamiliesJson  String?
  homeCarouselFlowSpeed   Int      @default(50)
  minSolutionLevelForUser Int      @default(1)
  /// 색상 테마 프리셋(saas|dark|brand|nature|custom). null이면 primary/secondary만 커스텀
  colorThemePreset        String?
  /// colorThemePreset === custom 일 때 토큰 JSON (마이그레이션 20260329140000)
  colorThemeCustomJson    String?
  /// 사이트 인트로 설정(JSON). ON/OFF, 제목/설명, 미디어, 링크, 표시시간, 스킵버튼
  introSettingsJson       String?
}

model AdminCopy {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SiteFeatureFlag {
  id      String  @id @default(cuid())
  key     String  @unique
  enabled Boolean @default(true)
}

model SystemText {
  id           String   @id @default(cuid())
  key          String   @unique
  group        String
  label        String
  description  String?
  value        String?
  defaultValue String?
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([group])
  @@index([key])
}

model SystemTextHistory {
  id        String   @id @default(cuid())
  textId    String
  key       String
  value     String?
  action    String
  adminId   String
  createdAt DateTime @default(now())

  @@index([textId])
  @@index([createdAt])
}

model AdminLog {
  id          String   @id @default(cuid())
  adminId     String
  actionType  String
  targetType  String
  targetId    String?
  beforeValue String?
  afterValue  String?
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model FeaturedContent {
  id        String   @id @default(cuid())
  type      String
  targetId  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([type, targetId])
  @@index([type, sortOrder])
}

model BackupRecord {
  id        String   @id @default(cuid())
  filename  String
  filePath  String
  sizeBytes Int
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model IntegrationSetting {
  id               String   @id @default(cuid())
  naverMapClientId String?
  updatedAt        DateTime @updatedAt
}

model NotificationSetting {
  id                          String   @id @default(cuid())
  adminEmail                  String?
  notifyNewRegistration       Boolean  @default(true)
  notifyRegistrationConfirmed Boolean  @default(true)
  notifyPaymentConfirmed      Boolean  @default(true)
  notifyAnnouncement          Boolean  @default(true)
  updatedAt                   DateTime @updatedAt
}

model PlatformSettings {
  id                  String   @id @default(cuid())
  billingEnabled      Boolean  @default(false)
  tournamentFee       Int      @default(30000)
  clientMembershipFee Int      @default(180000)
  updatedAt           DateTime @updatedAt
}

model ClientMembership {
  id             String       @id @default(cuid())
  organizationId String
  validFrom      DateTime     @default(now())
  validUntil     DateTime
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([validUntil])
}

model Feature {
  id                 String                      @id @default(cuid())
  code               String                      @unique
  name               String
  description        String?
  isActive           Boolean                     @default(true)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  organizationAccess OrganizationFeatureAccess[]
  planFeatures       PlanFeature[]
}

model PricingPlan {
  id             String                         @id @default(cuid())
  code           String                         @unique
  name           String
  description    String?
  planType       String
  billingType    String
  price          Int                            @default(0)
  currency       String                         @default("KRW")
  isActive       Boolean                        @default(true)
  validDays      Int?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  subscriptions  OrganizationPlanSubscription[]
  paymentRecords PaymentRecord[]
  planFeatures   PlanFeature[]
}

model PlanFeature {
  id        String      @id @default(cuid())
  planId    String
  featureId String
  createdAt DateTime    @default(now())
  feature   Feature     @relation(fields: [featureId], references: [id], onDelete: Cascade)
  plan      PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
  @@index([planId])
  @@index([featureId])
}

model OrganizationPlanSubscription {
  id              String       @id @default(cuid())
  organizationId  String
  planId          String
  status          String
  startedAt       DateTime     @default(now())
  expiresAt       DateTime?
  grantedByUserId String?
  sourceType      String
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan            PricingPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([planId])
  @@index([status, expiresAt])
}

model OrganizationFeatureAccess {
  id             String       @id @default(cuid())
  organizationId String
  featureId      String
  status         String
  startedAt      DateTime     @default(now())
  expiresAt      DateTime?
  sourceType     String
  sourceRefId    String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feature        Feature      @relation(fields: [featureId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([featureId])
  @@index([status, expiresAt])
}

model PaymentRecord {
  id                String       @id @default(cuid())
  organizationId    String
  planId            String?
  amount            Int          @default(0)
  currency          String       @default("KRW")
  status            String
  paidAt            DateTime?
  sourceType        String
  externalPaymentId String?
  createdByUserId   String?
  memo              String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  paymentType       String?
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan              PricingPlan? @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@index([planId])
  @@index([status])
}

model ListingProduct {
  id                   String                  @id @default(cuid())
  code                 String                  @unique
  name                 String
  description          String?
  postingMonths        Int                     @default(1)
  price                Int                     @default(0)
  currency             String                  @default("KRW")
  isActive             Boolean                 @default(true)
  appliesToGeneralOnly Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  purchases            ListingPurchaseRecord[]
}

model ListingPurchaseRecord {
  id               String         @id @default(cuid())
  organizationId   String
  listingProductId String
  targetType       String
  targetId         String?
  postingMonths    Int            @default(1)
  amount           Int            @default(0)
  status           String         @default("ACTIVE")
  startedAt        DateTime       @default(now())
  expiresAt        DateTime?
  createdAt        DateTime       @default(now())
  listingProduct   ListingProduct @relation(fields: [listingProductId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([listingProductId])
  @@index([status, expiresAt])
}

/// 홈·커뮤니티·대회 페이지 빌더용 초안 스냅샷. 게시 시 `PageSection`에 반영 후 행 삭제.
model CmsPageLayoutDraft {
  id        String   @id @default(cuid())
  /// home | community | tournaments
  page      String   @unique
  /// PageSection[] JSON (동일 스키마)
  sections  Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([page])
}

model PageSection {
  id                String    @id @default(cuid())
  type              String
  title             String
  subtitle          String?
  description       String?
  textAlign         String    @default("center")
  page              String
  placement         String
  imageUrl          String?
  imageUrlMobile    String?
  imageHeightPc     Int?
  imageHeightMobile Int?
  linkType          String    @default("none")
  internalPage      String?
  internalPath      String?
  externalUrl       String?
  openInNewTab      Boolean   @default(false)
  buttons           String?
  isVisible         Boolean   @default(true)
  sortOrder         Int       @default(0)
  startAt           DateTime?
  endAt             DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  backgroundColor   String?
  titleIconImageUrl String?
  titleIconName     String?
  titleIconSize     String?
  titleIconType     String?
  sectionStyleJson  String?
  /// 페이지 구조 슬롯(hero, postList 등). null이면 레거시 CMS 행 — type(image|text|cta)만 사용
  slotType          String?
  /// 슬롯별 소량 설정 JSON. 자유 HTML 금지
  slotConfigJson    String?
  /// 페이지 빌더 소프트 삭제(복원 가능). DB 컬럼은 `20260329170000_page_section_deleted_at` 한 곳에서만 추가(중복 마이그레이션 금지).
  deletedAt         DateTime?

  @@index([page, placement])
  @@index([page])
  @@index([page, slotType, sortOrder])
}

model Popup {
  id                  String    @id @default(cuid())
  title               String
  description         String?
  imageUrl            String?
  buttonName          String?
  buttonLink          String?
  page                String
  startAt             DateTime?
  endAt               DateTime?
  hideForTodayEnabled Boolean   @default(true)
  showCloseButton     Boolean   @default(true)
  isVisible           Boolean   @default(true)
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([page])
}

model NoticeBar {
  id              String    @id @default(cuid())
  message         String
  linkType        String    @default("none")
  internalPath    String?
  externalUrl     String?
  openInNewTab    Boolean   @default(false)
  backgroundColor String    @default("#1e3a5f")
  textColor       String    @default("#ffffff")
  page            String
  position        String    @default("below_header")
  startAt         DateTime?
  endAt           DateTime?
  isVisible       Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([page])
}

model Notice {
  id          String    @id @default(cuid())
  type        String
  title       String
  content     String    @default("")
  linkUrl     String?
  startAt     DateTime?
  endAt       DateTime?
  isActive    Boolean   @default(true)
  showOnce    Boolean   @default(false)
  showMobile  Boolean   @default(true)
  showDesktop Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([isActive, type])
}

model BilliardNote {
  id                   String            @id @default(cuid())
  authorId             String
  title                String?
  noteDate             DateTime?
  redBallX             Float
  redBallY             Float
  yellowBallX          Float
  yellowBallY          Float
  whiteBallX           Float
  whiteBallY           Float
  cueBall              String
  memo                 String?
  imageUrl             String?
  visibility           String            @default("private")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  author               User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  nanguPostsFromNote   NanguPost?
  troubleShotsFromNote TroubleShotPost[]

  @@index([authorId])
  @@index([visibility, createdAt])
}

model NanguPost {
  id                String          @id @default(cuid())
  authorId          String
  title             String
  content           String
  ballPlacementJson String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  adoptedSolutionId String?         @unique(map: "NanguPost_adoptedSolutionId_key_v2")
  sourceNoteId      String?         @unique
  adoptedSolution   NanguSolution?  @relation("AdoptedSolution", fields: [adoptedSolutionId], references: [id])
  author            User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sourceNote        BilliardNote?   @relation(fields: [sourceNoteId], references: [id])
  solutions         NanguSolution[]

  @@index([authorId])
  @@index([createdAt])
}

model NanguSolution {
  id                    String                  @id @default(cuid())
  postId                String
  authorId              String
  createdAt             DateTime                @default(now())
  description           String?
  isAccepted            Boolean                 @default(false)
  pathData              Json
  playbackFrames        Json?
  settings              Json
  thumbnailSvg          String?
  title                 String?
  comment               String?
  dataJson              String                  @default("{}")
  voteCount             Int                     @default(0)
  goodCount             Int                     @default(0)
  badCount              Int                     @default(0)
  updatedAt             DateTime                @default(now()) @updatedAt
  adoptedByPost         NanguPost?              @relation("AdoptedSolution")
  author                User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post                  NanguPost               @relation(fields: [postId], references: [id], onDelete: Cascade)
  NanguSolutionComment  NanguSolutionComment[]
  NanguSolutionReaction NanguSolutionReaction[]

  @@index([postId])
  @@index([authorId])
}

model CommunityBoard {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  description String?
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  type        String          @default("free")
  isActive    Boolean         @default(true)
  posts       CommunityPost[]

  @@index([sortOrder])
  @@index([type, isActive])
}

model CommunityPost {
  id           String              @id @default(cuid())
  boardId      String
  authorId     String
  title        String
  content      String
  imageUrls    String?
  isPinned     Boolean             @default(false)
  isHidden     Boolean             @default(false)
  viewCount    Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  thumbnailUrl String?
  likeCount    Int                 @default(0)
  commentCount Int                 @default(0)
  isSolved     Boolean             @default(false)
  bookmarks    CommunityBookmark[]
  comments     CommunityComment[]
  author       User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  board        CommunityBoard      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  likes        CommunityPostLike[]
  postViews    CommunityPostView[]
  reports      CommunityReport[]
  troubleShot  TroubleShotPost?

  @@index([boardId])
  @@index([authorId])
  @@index([boardId, isPinned, createdAt])
  @@index([boardId, isHidden, createdAt])
  @@index([boardId, isHidden, viewCount])
  @@index([boardId, isHidden, likeCount])
  @@index([boardId, isHidden, commentCount])
  @@index([boardId, isHidden, isSolved, createdAt])
  @@index([boardId, isHidden, title])
  @@index([createdAt])
  @@index([isHidden])
  @@index([title(ops: raw("gin_trgm_ops"))], map: "CommunityPost_title_gin_trgm_idx", type: Gin)
}

model CommunityPostView {
  id        String        @id @default(cuid())
  postId    String
  viewerKey String
  userId    String?
  viewedAt  DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, viewerKey])
  @@index([postId])
  @@index([viewedAt])
}

model CommunityComment {
  id        String                 @id @default(cuid())
  postId    String
  parentId  String?
  authorId  String
  content   String
  isHidden  Boolean                @default(false)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  author    User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    CommunityComment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  children  CommunityComment[]     @relation("CommentReplies")
  post      CommunityPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  likes     CommunityCommentLike[]
  reports   CommunityReport[]

  @@index([postId])
  @@index([parentId])
  @@index([authorId])
}

model CommunityPostLike {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model CommunityCommentLike {
  id        String           @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime         @default(now())
  comment   CommunityComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model CommunityBookmark {
  id        String        @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model CommunityNotification {
  id            String    @id @default(cuid())
  userId        String
  type          String
  postId        String
  commentId     String?
  relatedUserId String
  readAt        DateTime?
  createdAt     DateTime  @default(now())
  relatedUser   User      @relation("NotificationActor", fields: [relatedUserId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@map("community_notifications")
}

model CommunityReport {
  id          String            @id @default(cuid())
  reporterId  String
  targetType  String
  targetId    String
  postId      String?
  commentId   String?
  reason      String
  status      String            @default("PENDING")
  adminMemo   String?
  processedAt DateTime?
  processedBy String?
  createdAt   DateTime          @default(now())
  comment     CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  post        CommunityPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter    User              @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([status])
}

model CommunityScoreLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Int
  refType   String?
  refId     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model TroubleShotPost {
  id                 String                @id @default(cuid())
  postId             String                @unique
  sourceNoteId       String?
  layoutImageUrl     String?
  difficulty         String?
  isSolved           Boolean               @default(false)
  acceptedSolutionId String?
  ballPlacementJson  String?
  post               CommunityPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  sourceNote         BilliardNote?         @relation(fields: [sourceNoteId], references: [id])
  solutions          TroubleShotSolution[]

  @@index([postId])
  @@index([sourceNoteId])
  @@index([isSolved])
}

model TroubleShotSolution {
  id                String                    @id @default(cuid())
  troubleShotPostId String
  authorId          String
  title             String?
  content           String
  solutionImageUrl  String?
  voteCount         Int                       @default(0)
  isAccepted        Boolean                   @default(false)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  goodCount         Int                       @default(0)
  badCount          Int                       @default(0)
  solutionDataJson  String?
  author            User                      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  troubleShotPost   TroubleShotPost           @relation(fields: [troubleShotPostId], references: [id], onDelete: Cascade)
  votes             TroubleShotSolutionVote[]

  @@index([troubleShotPostId])
  @@index([authorId])
}

model TroubleShotSolutionVote {
  id         String                      @id @default(cuid())
  solutionId String
  userId     String
  vote       TroubleShotSolutionVoteType
  createdAt  DateTime                    @default(now())
  solution   TroubleShotSolution         @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  user       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([solutionId, userId])
  @@index([solutionId])
  @@index([userId])
}

model Inquiry {
  id        String    @id @default(cuid())
  userId    String
  title     String
  content   String
  reply     String?
  replyAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NanguSolutionComment {
  id            String        @id
  solutionId    String
  userId        String
  content       String
  createdAt     DateTime      @default(now())
  NanguSolution NanguSolution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  User          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([solutionId])
  @@index([userId])
}

model NanguSolutionReaction {
  solutionId    String
  userId        String
  type          NanguSolutionReactionType
  NanguSolution NanguSolution             @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  User          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([solutionId, userId])
  @@index([solutionId])
  @@index([userId])
}

enum UserRole {
  USER
  CLIENT_ADMIN
  PLATFORM_ADMIN
  MODERATOR
  ZONE_MANAGER
}

enum TroubleShotSolutionVoteType {
  GOOD
  BAD
}

enum NanguSolutionReactionType {
  GOOD
  BAD
}
