  id               String             @id @default(cuid())
  bracketId        String
  roundId          String
  venueId          String?
  matchNumber      Int
  tableOrder       Int?
  displayOrder     Int?
  entryIdA         String?
  entryIdB         String?
  winnerEntryId    String?
  scoreA           Int?
  scoreB           Int?
  status           BracketMatchStatus @default(PENDING)
  isBye            Boolean            @default(false)
  isReduction      Boolean            @default(false)
  isManualOverride Boolean            @default(false)
  nextMatchId      String?
  nextSlot         String?
  startedAt        DateTime?
  completedAt      DateTime?
  note             String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  scheduledStartAt DateTime?
  hasIssue         Boolean            @default(false)
  issueNote        String?
