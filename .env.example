# ===========================================
# CAROM.CLUB (캐롬클럽) 환경 변수 예시
# 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
# ===========================================
#
# [Vercel/배포 필수] 다음 3개는 배포 환경에서 반드시 설정하세요.
#   DATABASE_URL  - Neon PostgreSQL 연결 문자열 (Prisma 쿼리용)
#   DIRECT_URL   - Neon PostgreSQL 직연결 (마이그레이션/generate용)
#   SESSION_SECRET - 로그인 세션 서명 키 (32자 이상 랜덤)
#
# ===========================================

# [선택] 공개 사이트 URL (메타 태그, Open Graph 등). 없으면 https://carom.club 사용.
# NEXT_PUBLIC_SITE_URL=https://carom.club

# [DB] Neon PostgreSQL. Vercel/배포 시 필수.
# 예: DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
#     DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# [필수] 로그인 세션(JWT) 서명용 비밀키. 32자 이상 랜덤 권장. Vercel/배포 시 필수.
# 생성 예: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="your-secret-at-least-32-chars"

# [선택] www / non-www 둘 다 쓸 때 세션 쿠키 공유 (carom.club ↔ www.carom.club).
# 로그인은 한 호스트로만 통일하는 것이 가장 안전. 둘 다 살릴 때만 설정.
# 예: SESSION_COOKIE_DOMAIN=carom.club  → 쿠키 Domain=.carom.club 로 발급
# SESSION_COOKIE_DOMAIN=carom.club

# [선택] 배포에서만: billiard-notes 등 401 시 쿠키 전달 여부 서버 로그 (1=켜기)
# AUTH_DEBUG_COOKIE=1

# [선택] 시드 시 생성할 관리자 계정 (npm run db:seed 시 사용). 없으면 admin / admin1234
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=your-secure-password
# SEED_ADMIN_EMAIL=admin@example.com

# [선택] 이미지 업로드용 (Vercel Blob) - 사이트 로고, 대회/당구장 이미지, 마이페이지 AVG 증빙 등
# 없으면 로컬에 public/uploads 로 저장되어 로컬에서 이미지 표시 가능. 배포 시 토큰 설정하면 Blob 사용.
# 발급: Vercel 대시보드 → 프로젝트 → Storage → Create Database → Blob → .env.local에 토큰 복사
# BLOB_READ_WRITE_TOKEN=
BLOB_READ_WRITE_TOKEN=

# [선택] 네이버 지도 JavaScript API (당구장 오시는 길 등)
# 관리자 > 연동 설정에서 입력해 저장할 수도 있음. DB 우선, 없으면 이 env 사용.
# NAVER_MAP_CLIENT_ID=
